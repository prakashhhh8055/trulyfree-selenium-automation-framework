<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Grouping Suite" thread-count="5">

  <listeners>
 	 <listener class-name="utilities.ExtentReportManager"/>
  </listeners>
  
	<groups>
		<run>
			<include name="sanity"/>
		</run>
	</groups>
  <test name="ChromeTest">
	  <parameter name="os" value="windows"/>
	  <parameter name="browser" value="chrome"/>
    <classes>
      <class name="testCases.TC002_AccountRegistrationTest"/> 
      <class name="testCases.TC001_LoginTest"/>
      <class name="testCases.TC003_LoginViaEmailAndPwd"/>
      <class name="testCases.LoginAndLogoutTest"/>
      <class name="testCases.TC004_LoginViaEmailAndPasswordDDTTest"/>
      
    </classes>
  </test>  
  
</suite> <!-- Suite -->

